---
import BaseLayout from "./BaseLayout.astro";

export interface Props {
  title: string;
  description?: string;

  pubDate?: Date;
  updatedDate?: Date;

  category?: string;

  tags?: string[];

  author?: string;

  heroImage?: string;
}

const {
  title,
  description,

  pubDate,
  updatedDate,

  category,

  tags = [],

  author = "AI Praktis Indonesia",

  heroImage,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
>

  <article class="mx-auto max-w-4xl px-6 py-12">

    <slot />

  </article>

</BaseLayout>