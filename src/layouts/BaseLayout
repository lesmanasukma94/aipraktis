---
import "@/styles/global.css";
import { SITE } from "@/config/site";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = SITE.title,
  description = SITE.description,
} = Astro.props;
---

<!doctype html>
<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1.0"
    />

    <title>{title}</title>

    <meta
      name="description"
      content={description}
    />

    <meta
      name="generator"
      content={Astro.generator}
    />

    <link
      rel="icon"
      href="/favicon.ico"
    />
  </head>

  <body>

    <slot />

  </body>
</html>