---
import BaseLayout from "@/layouts/BaseLayout.astro";
import CategoryHero from "@/components/category/CategoryHero.astro";
import CategorySidebar from "@/components/category/CategorySidebar.astro";

export interface Props {
  category: {
    slug: string;
    name: string;
    description: string;
  };
}

const { category } = Astro.props;
---

<BaseLayout
  title={category.name}
  description={category.description}
>
  <CategoryHero category={category} />

  <div class="category-layout">
    <main class="category-content">
      <slot />
    </main>

    <CategorySidebar
      currentSlug={category.slug}
    />
  </div>
</BaseLayout>

<style>
  .category-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 32px;
    width: min(calc(100% - 3rem), 1200px);
    margin-inline: auto;
    padding-block: 24px 80px;
    align-items: start;
  }

  .category-content {
    display: grid;
    gap: 32px;
    min-width: 0;
  }

  @media (max-width: 960px) {
    .category-layout {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 640px) {
    .category-layout {
      width: min(calc(100% - 1.5rem), 1200px);
      padding-block: 20px 56px;
    }

    .category-content {
      gap: 24px;
    }
  }
</style>
