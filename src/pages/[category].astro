---
import { getCollection } from "astro:content";

import CategoryLayout from "@/layouts/CategoryLayout.astro";
import FeaturedPost from "@/components/category/FeaturedPost.astro";
import CategoryPosts from "@/components/category/CategoryPosts.astro";
import CategoryFAQ from "@/components/category/CategoryFAQ.astro";
import CategoryCTA from "@/components/category/CategoryCTA.astro";
import RelatedCategories from "@/components/category/RelatedCategories.astro";
import RelatedArticles from "@/components/category/RelatedArticles.astro";
import CategoryNavigation from "@/components/category/CategoryNavigation.astro";
import CategoryTopicClusters from "@/components/category/CategoryTopicClusters.astro";

import { categories } from "@/data/categories";

export async function getStaticPaths() {

  const allPosts = await getCollection("blog");

  return categories.map((category) => ({

    params: {
      category: category.slug,
    },

    props: {

      category,

      posts: allPosts.filter(
        (post) => post.data.category === category.slug
      ),

    },

  }));

}

const {
  category,
  posts,
} = Astro.props;

const categoryUrl =
  `https://www.aipraktis.co.id/${category.slug}/`;

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",

  name: category.name,

  description: category.description,

  url: categoryUrl,

  isPartOf: {
    "@type": "WebSite",
    name: "AI Praktis Indonesia",
    url: "https://www.aipraktis.co.id"
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",

  itemListElement: [

    {
      "@type": "ListItem",
      position: 1,
      name: "Beranda",
      item: "https://www.aipraktis.co.id/"
    },

    {
      "@type": "ListItem",
      position: 2,
      name: category.name,
      item: categoryUrl
    }

  ]
};
---

<CategoryLayout category={category}>

<script
  slot="head"
  type="application/ld+json"
  set:html={JSON.stringify(collectionSchema)}
/>

<script
  slot="head"
  type="application/ld+json"
  set:html={JSON.stringify(breadcrumbSchema)}
/>

<FeaturedPost
  post={posts[0]}
/>

<CategoryTopicClusters
  category={category.slug}
/>

<RelatedArticles
  posts={posts.slice(1)}
/>

  <CategoryPosts
    posts={posts.slice(1)}
  />

  <CategoryFAQ
    category={category}
  />

<CategoryCTA
  category={category}
/>

<RelatedCategories
  currentSlug={category.slug}
/>

<CategoryNavigation
  currentSlug={category.slug}
/>

</CategoryLayout>