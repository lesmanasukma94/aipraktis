---
import { getCollection } from "astro:content";

import CategoryLayout from "@/layouts/CategoryLayout.astro";
import FeaturedPost from "@/components/category/FeaturedPost.astro";
import CategoryPosts from "@/components/category/CategoryPosts.astro";
import CategoryFAQ from "@/components/category/CategoryFAQ.astro";
import CategoryCTA from "@/components/category/CategoryCTA.astro";
import RelatedCategories from "@/components/category/RelatedCategories.astro";
import RelatedArticles from "@/components/category/RelatedArticles.astro";
import CategoryNavigation from "@/components/category/CategoryNavigation.astro";
import CategoryTopicClusters from "@/components/category/CategoryTopicClusters.astro";
import CategoryLearningPaths from "@/components/category/CategoryLearningPaths.astro";
import SeriesOverview from "@/components/category/SeriesOverview.astro";

import { categories } from "@/data/categories";

import {
  buildCollectionSchema,
  buildBreadcrumbSchema,
} from "@/lib/schema-engine";

export async function getStaticPaths() {
  const allPosts = await getCollection("blog");

  const categoryArticlePriority = {
    "belajar-ai": [
      "ai-untuk-pemula",
      "apa-itu-ai",
      "cara-belajar-ai-dari-nol",
      "roadmap-belajar-ai",
      "skill-ai",
      "apakah-ai-aman",
      "kesalahan-pemula-saat-belajar-ai",
      "kursus-ai-gratis-terbaik",
      "ai-agent-untuk-pemula",
    ],
  };

  return categories.map((category) => {
    const priorityList = categoryArticlePriority[category.slug] ?? [];

    const posts = allPosts
      .filter((post) => post.data.category === category.slug)
      .sort((a, b) => {
        const slugA =
          a.slug ?? a.id?.replace(/\.mdx?$/, "");

        const slugB =
          b.slug ?? b.id?.replace(/\.mdx?$/, "");

        const rankA =
          priorityList.includes(slugA)
            ? priorityList.indexOf(slugA)
            : Number.POSITIVE_INFINITY;

        const rankB =
          priorityList.includes(slugB)
            ? priorityList.indexOf(slugB)
            : Number.POSITIVE_INFINITY;

        if (rankA !== rankB) {
          return rankA - rankB;
        }

        if ((a.data.featured ?? false) !== (b.data.featured ?? false)) {
          return Number(b.data.featured ?? false) - Number(a.data.featured ?? false);
        }

        return (
          new Date(b.data.pubDate).getTime() -
          new Date(a.data.pubDate).getTime()
        );
      });

    return {
      params: {
        category: category.slug,
      },

      props: {
        category,
        posts,
      },
    };
  });
}

const {
  category,
  posts,
} = Astro.props;

const categoryUrl =
  `https://www.aipraktis.co.id/${category.slug}/`;

const collectionSchema =
  buildCollectionSchema(
    category,
    categoryUrl
  );

const breadcrumbSchema =
  buildBreadcrumbSchema([
    {
      name: "Beranda",
      url: "https://www.aipraktis.co.id/",
    },
    {
      name: category.name,
      url: categoryUrl,
    },
  ]);
---

<CategoryLayout category={category}>

  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(collectionSchema)}
  />

  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />

  <FeaturedPost
    post={posts[0]}
  />

  <CategoryLearningPaths
    category={category.slug}
  />

  <SeriesOverview
    category={category.slug}
  />

  <CategoryTopicClusters
    category={category.slug}
  />

  <RelatedArticles
    posts={posts.slice(1)}
  />

  <CategoryPosts
    posts={posts.slice(1)}
  />

  <CategoryFAQ
    category={category}
  />

  <CategoryCTA
    category={category}
  />

  <RelatedCategories
    currentSlug={category.slug}
  />

  <CategoryNavigation
    currentSlug={category.slug}
  />

</CategoryLayout>