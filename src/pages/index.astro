---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

posts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() -
    new Date(a.data.pubDate).getTime()
);

const latestPosts = posts.slice(0, 6);
---

<Layout title="AI Praktis Indonesia | Belajar AI Praktis untuk Pemula, Pekerja, dan UMKM">

<section class="hero">

  <h1>
    Belajar ChatGPT, Gemini, dan AI untuk Produktivitas, Karier, dan Bisnis
  </h1>

  <p>
    AI Praktis Indonesia membantu pemula, pekerja, freelancer,
    content creator, dan pelaku UMKM memahami serta menggunakan
    Artificial Intelligence secara sederhana, praktis, dan langsung
    dapat diterapkan.
  </p>

  <a href="/blog" class="btn">
    Mulai Belajar AI
  </a>

</section>

<section class="stats">

  <div class="stat-card">
    <h3>10+</h3>
    <p>Artikel AI Praktis</p>
  </div>

  <div class="stat-card">
    <h3>4</h3>
    <p>Kategori Utama</p>
  </div>

  <div class="stat-card">
    <h3>100%</h3>
    <p>Bahasa Indonesia</p>
  </div>

  <div class="stat-card">
    <h3>Pemula</h3>
    <p>Fokus Utama</p>
  </div>

</section>

<section class="why-ai">

  <h2>Mengapa Belajar AI Sekarang?</h2>

  <p>
    Artificial Intelligence telah menjadi teknologi yang mengubah
    cara manusia bekerja, belajar, berbisnis, dan berkarya.
    Dengan memahami AI sejak sekarang, Anda dapat meningkatkan
    produktivitas, menghemat waktu, menemukan ide baru,
    dan mempersiapkan diri menghadapi masa depan digital.
  </p>

</section>

<section class="audience">

  <h2>Website Ini Cocok Untuk</h2>

  <div class="categories">

    <div class="card">
      <h3>Pemula</h3>
      <p>Belajar AI dari dasar tanpa istilah teknis yang rumit.</p>
    </div>

    <div class="card">
      <h3>Karyawan</h3>
      <p>Meningkatkan produktivitas kerja dengan bantuan AI.</p>
    </div>

    <div class="card">
      <h3>Freelancer</h3>
      <p>Menyelesaikan pekerjaan lebih cepat dan efisien.</p>
    </div>

    <div class="card">
      <h3>UMKM</h3>
      <p>Memanfaatkan AI untuk pemasaran dan pengembangan bisnis.</p>
    </div>

  </div>

</section>

<section class="start-here">

  <h2>Mulai Belajar AI Dari Sini</h2>

  <div class="post-grid">

    <article class="post-card">
      <h3>
        <a href="/blog/apa-itu-ai/">
          Apa Itu Artificial Intelligence (AI)?
        </a>
      </h3>
    </article>

    <article class="post-card">
      <h3>
        <a href="/blog/chatgpt-untuk-pemula/">
          ChatGPT untuk Pemula
        </a>
      </h3>
    </article>

    <article class="post-card">
      <h3>
        <a href="/blog/cara-menggunakan-chatgpt-untuk-pekerjaan-sehari-hari/">
          Cara Menggunakan ChatGPT untuk Pekerjaan Sehari-hari
        </a>
      </h3>
    </article>

    <article class="post-card">
      <h3>
        <a href="/blog/gemini-ai-untuk-pemula/">
          Gemini AI untuk Pemula
        </a>
      </h3>
    </article>

  </div>

</section>

<section class="categories-section">

  <h2>Kategori Utama</h2>

  <div class="categories">

    <div class="card">
      <h3>Belajar AI</h3>
      <p>Panduan dasar memahami Artificial Intelligence untuk pemula.</p>
    </div>

    <div class="card">
      <h3>Prompt AI</h3>
      <p>Kumpulan prompt siap pakai untuk berbagai kebutuhan.</p>
    </div>

    <div class="card">
      <h3>AI untuk UMKM</h3>
      <p>Strategi memanfaatkan AI untuk pemasaran dan bisnis.</p>
    </div>

    <div class="card">
      <h3>AI untuk Pekerja</h3>
      <p>Meningkatkan produktivitas dan efisiensi kerja.</p>
    </div>

  </div>

</section>

<section class="latest-posts">

  <h2>Artikel Terbaru</h2>

  <div class="post-grid">

    {latestPosts.map((post) => (

      <article class="post-card">

        <h3>
          <a href={`/blog/${post.id}/`}>
            {post.data.title}
          </a>
        </h3>

        <p>
          {post.data.description}
        </p>

      </article>

    ))}

  </div>

</section>

<section class="about-site">

  <h2>Tentang AI Praktis Indonesia</h2>

  <p>
    AI Praktis Indonesia adalah website edukasi AI berbahasa Indonesia
    yang membantu masyarakat memahami dan memanfaatkan teknologi AI
    secara sederhana, praktis, dan mudah diterapkan dalam kehidupan,
    pekerjaan, maupun bisnis.
  </p>

</section>

<section class="cta">

  <h2>Mulai Belajar AI Hari Ini</h2>

  <p>
    Jelajahi berbagai panduan, tutorial, prompt, dan strategi AI
    yang dirancang khusus untuk pemula dan profesional.
  </p>

  <a href="/blog" class="btn">
    Lihat Semua Artikel
  </a>

</section>

<style>
.hero{
  text-align:center;
  padding:60px 0;
}

.hero h1{
  font-size:48px;
  margin-bottom:20px;
}

.hero p{
  max-width:800px;
  margin:0 auto 30px;
}

.btn{
  display:inline-block;
  padding:14px 28px;
  background:#2563eb;
  color:white;
  text-decoration:none;
  border-radius:10px;
  font-weight:bold;
}

.stats{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
  gap:20px;
  margin-top:40px;
}

.stat-card{
  text-align:center;
  border:1px solid #e5e7eb;
  border-radius:16px;
  padding:24px;
  background:white;
}

.stat-card h3{
  margin:0;
  font-size:32px;
}

.why-ai,
.audience,
.start-here,
.categories-section,
.latest-posts,
.about-site,
.cta{
  margin-top:80px;
}

.categories,
.post-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
  gap:24px;
  margin-top:30px;
}

.card,
.post-card{
  background:white;
  border:1px solid #e5e7eb;
  border-radius:16px;
  padding:24px;
}

.post-card a{
  text-decoration:none;
}

.cta{
  text-align:center;
  padding:50px 20px;
  border:1px solid #e5e7eb;
  border-radius:20px;
  background:white;
}
</style>

</Layout>