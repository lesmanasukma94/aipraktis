---
import Layout from "../layouts/Layout.astro";

import Hero from "@/components/home/Hero.astro";
import QuickSearch from "@/components/home/QuickSearch.astro";
import QuickStats from "@/components/home/QuickStats.astro";
import HubSection from "@/components/home/HubSection.astro";
import LearningPath from "@/components/home/LearningPath.astro";
import ToolsSection from "@/components/home/ToolsSection.astro";
import BusinessSection from "@/components/home/BusinessSection.astro";
import CreatorSection from "@/components/home/CreatorSection.astro";
import LatestPosts from "@/components/home/LatestPosts.astro";

import { getCollection } from "astro:content";

const posts = await getCollection("blog");

posts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() -
    new Date(a.data.pubDate).getTime()
);

const latestPosts = posts.slice(0, 6);
---

<Layout title="AI Praktis Indonesia | Belajar AI Praktis untuk Pemula, Pekerja, dan UMKM">

