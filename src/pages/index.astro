---
import { getCollection } from "astro:content";

import BaseLayout from "@/layouts/BaseLayout.astro";

import HeroSection from "@/components/home/HeroSection.astro";
import CategoryGrid from "@/components/home/CategoryGrid.astro";
import VendorSection from "@/components/home/VendorSection.astro";
import ToolsSection from "@/components/home/ToolsSection.astro";
import FeaturedArticles from "@/components/home/FeaturedArticles.astro";
import ComparisonSection from "@/components/home/ComparisonSection.astro";
import LeadMagnet from "@/components/home/LeadMagnet.astro";
import CTASection from "@/components/home/CTASection.astro";

import { SITE } from "@/config/site";

const posts = await getCollection(
  "blog",
  ({ data }) => !data.draft
);

const categoryCount = new Set(
  posts.map((post) => post.data.category)
).size;

const homepageUrl = `${SITE.url}/`;
---

<BaseLayout
  title="AI Praktis Indonesia | Belajar AI untuk Karier, Bisnis, dan Produktivitas"
  description="Panduan praktis AI, ChatGPT, Claude, Gemini, AI tools, dan prompt engineering untuk pemula, pekerja, bisnis, pendidikan, serta content creator."
  canonical={homepageUrl}
>

  <HeroSection
    articleCount={posts.length}
    categoryCount={categoryCount}
  />

  <CategoryGrid />

  <VendorSection />

  <ToolsSection />

  <FeaturedArticles posts={posts} />

  <ComparisonSection />

  <LeadMagnet />

  <CTASection />

</BaseLayout>
