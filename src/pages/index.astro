---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog");

posts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() -
    new Date(a.data.pubDate).getTime()
);

const latestPosts = posts.slice(0, 6);
---

<Layout title="AI Praktis Indonesia | Belajar AI Praktis untuk Pemula, Pekerja, dan UMKM">

<!-- ========================= -->
<!-- HERO -->
<!-- ========================= -->

<section class="hero-v2">

  <div class="hero-content">

    <span class="hero-badge">
      🇮🇩 Portal Belajar Artificial Intelligence Indonesia
    </span>

    <h1>
      Belajar AI, ChatGPT, Gemini, AI Agent & Prompt Engineering
      untuk Pemula, Pekerja, Freelancer, dan UMKM
    </h1>

    <p>
      AI Praktis Indonesia membantu Anda memahami Artificial Intelligence
      secara praktis melalui ratusan panduan, tutorial, tools AI,
      prompt ChatGPT, AI untuk bisnis, AI coding,
      hingga peluang karier di era AI.
    </p>

    <div class="hero-buttons">

      <a class="btn-primary" href="/blog">
        📚 Mulai Belajar AI
      </a>

      <a class="btn-secondary" href="/blog/roadmap-belajar-ai/">
        🚀 Lihat Roadmap AI
      </a>

    </div>

  </div>

</section>

<!-- ========================= -->
<!-- QUICK SEARCH -->
<!-- ========================= -->

<section class="quick-search">

<h2>
Cari Panduan AI
</h2>

<p>
Temukan lebih dari 140+ artikel AI Praktis Indonesia.
</p>

<form
action="/blog"
method="get"
class="search-box">

<input
type="text"
placeholder="Contoh: ChatGPT, AI Agent, Prompt Engineering, SEO AI">

<button>

Cari

</button>

</form>

</section>

<!-- ========================= -->
<!-- QUICK STATS -->
<!-- ========================= -->

<section class="quick-stats">

<div class="stat">

<h3>140+</h3>

<p>Artikel AI</p>

</div>

<div class="stat">

<h3>20+</h3>

<p>Kategori AI</p>

</div>

<div class="stat">

<h3>100%</h3>

<p>Bahasa Indonesia</p>

</div>

<div class="stat">

<h3>Gratis</h3>

<p>Panduan AI</p>

</div>

</section>