---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import BlogCard from "@/components/blog/BlogCard.astro";

const posts = await getCollection("blog");

posts.sort(
  (a, b) =>
    new Date(b.data.pubDate).getTime() -
    new Date(a.data.pubDate).getTime()
);
---

<BaseLayout
title="Blog AI Praktis Indonesia"
description="Tutorial AI, ChatGPT, Gemini, Prompt Engineering dan AI Bisnis."
>

<h1>Blog AI Praktis Indonesia</h1>

<p>
  Kumpulan artikel tentang ChatGPT, Claude, Gemini,
  Prompt AI, produktivitas, dan AI untuk UMKM.
</p>

<div class="blog-grid">

  {posts.map((post) => (

<BlogCard
  post={post}
/>

  ))}

</div>

</BaseLayout>
