---
import { getCollection } from "astro:content";

import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/config/site";

export async function getStaticPaths() {
  const posts = await getCollection(
    "blog",
    ({ data }) => !data.draft
  );

  const categoryMap = new Map();

  for (const post of posts) {
    const category = post.data.category;

    if (!categoryMap.has(category)) {
      categoryMap.set(category, []);
    }

    categoryMap.get(category).push(post);
  }

  return [...categoryMap.entries()].map(
    ([category, categoryPosts]) => ({
      params: {
        category,
      },
      props: {
        category,
        posts: categoryPosts,
      },
    })
  );
}

const { category, posts } = Astro.props;

const categoryNames: Record<string, string> = {
  "belajar-ai": "Belajar AI",
  "ai-chatbot": "AI Chatbot",
  "prompt-engineering": "Prompt Engineering",
  "ai-tools": "AI Tools",
  "tutorial-ai": "Tutorial AI",
  "ai-untuk-bisnis": "AI untuk Bisnis",
  "ai-untuk-pendidikan": "AI untuk Pendidikan",
  "ai-untuk-content-creator": "AI untuk Content Creator",
  "karier-ai": "Karier AI",
  "studi-kasus-ai": "Studi Kasus AI",
};

const categoryName =
  categoryNames[category] ??
  category
    .split("-")
    .map(
      (word: string) =>
        word.charAt(0).toUpperCase() +
        word.slice(1)
    )
    .join(" ");

const sortedPosts = [...posts].sort(
  (firstPost, secondPost) =>
    secondPost.data.pubDate.getTime() -
    firstPost.data.pubDate.getTime()
);

const canonical =
  `${SITE.url}/blog/category/${category}/`;

const dateFormatter =
  new Intl.DateTimeFormat("id-ID", {
    day: "numeric",
    month: "long",
    year: "numeric",
    timeZone: "UTC",
  });
---

<BaseLayout
  title={`${categoryName} | AI Praktis Indonesia`}
  description={`Kumpulan artikel, panduan, dan tutorial dalam kategori ${categoryName} di AI Praktis Indonesia.`}
  canonical={canonical}
>
  <article class="category-page">

    <nav
      class="category-breadcrumb"
      aria-label="Breadcrumb"
    >
      <a href="/">Beranda</a>
      <span aria-hidden="true">/</span>
      <a href="/blog/">Blog</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">
        {categoryName}
      </span>
    </nav>

    <header class="category-header">
      <p class="category-eyebrow">
        Kategori
      </p>

      <h1>
        {categoryName}
      </h1>

      <p>
        Kumpulan artikel dan panduan praktis tentang
        {` ${categoryName}`} untuk pembaca Indonesia.
      </p>

      <p class="category-count">
        {sortedPosts.length} artikel tersedia
      </p>
    </header>

    <section
      class="category-grid"
      aria-label={`Artikel kategori ${categoryName}`}
    >
      {
        sortedPosts.map((post) => (
          <article class="category-card">
            <p class="category-card-date">
              {dateFormatter.format(post.data.pubDate)}
            </p>

            <h2>
              <a href={`/blog/${post.id}/`}>
                {post.data.title}
              </a>
            </h2>

            <p>
              {post.data.description}
            </p>

            <a
              href={`/blog/${post.id}/`}
              class="category-read-link"
              aria-label={`Baca ${post.data.title}`}
            >
              Baca artikel
            </a>
          </article>
        ))
      }
    </section>

  </article>
</BaseLayout>

<style>
  .category-page {
    width: min(calc(100% - 2rem), 1120px);
    margin-inline: auto;
    padding-block: 2rem 5rem;
  }

  .category-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
    color: #64748b;
    font-size: 0.875rem;
  }

  .category-breadcrumb a {
    color: #2563eb;
    text-decoration: none;
  }

  .category-breadcrumb a:hover {
    text-decoration: underline;
  }

  .category-header {
    max-width: 800px;
    margin-bottom: 3rem;
  }

  .category-eyebrow {
    margin: 0 0 0.75rem;
    color: #2563eb;
    font-size: 0.875rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .category-header h1 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(2.25rem, 6vw, 4rem);
    font-weight: 850;
    line-height: 1.05;
    letter-spacing: -0.04em;
  }

  .category-header > p:not(.category-eyebrow):not(.category-count) {
    margin: 1.25rem 0 0;
    color: #475569;
    font-size: 1.125rem;
    line-height: 1.75;
  }

  .category-count {
    margin: 1rem 0 0;
    color: #64748b;
    font-size: 0.9375rem;
    font-weight: 700;
  }

  .category-grid {
    display: grid;
    gap: 1.25rem;
  }

  .category-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    background: #ffffff;
  }

  .category-card-date {
    margin: 0 0 0.65rem;
    color: #64748b;
    font-size: 0.8125rem;
  }

  .category-card h2 {
    margin: 0;
    font-size: 1.3rem;
    line-height: 1.4;
  }

  .category-card h2 a {
    color: #0f172a;
    text-decoration: none;
  }

  .category-card h2 a:hover {
    color: #2563eb;
  }

  .category-card > p:not(.category-card-date) {
    margin: 0.85rem 0 1.25rem;
    color: #64748b;
    line-height: 1.7;
  }

  .category-read-link {
    margin-top: auto;
    color: #2563eb;
    font-weight: 750;
    text-decoration: none;
  }

  .category-read-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (min-width: 720px) {
    .category-grid {
      grid-template-columns:
        repeat(2, minmax(0, 1fr));
    }
  }
</style>
