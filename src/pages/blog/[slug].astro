---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import RelatedLinks from "@/components/blog/RelatedLinks.astro";
import BackToCategory from "@/components/blog/BackToCategory.astro";
import CategoryHubCard from "@/components/blog/CategoryHubCard.astro";
import TopicClusterBox from "@/components/blog/TopicClusterBox.astro";
import LearningPathBox from "@/components/blog/LearningPathBox.astro";
import LearningPathNavigation from "@/components/blog/LearningPathNavigation.astro";
import SeriesProgress from "@/components/blog/SeriesProgress.astro";

import {
  getRelatedPosts,
  getCluster,
  getClusterPosts,
  getLearningPath,
  getPreviousStep,
  getNextStep,
} from "@/lib/content-engine";

import {
  buildArticleSchema,
  buildBreadcrumbSchema,
} from "@/lib/schema-engine";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: {
      slug: post.id,
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection("blog");

const relatedPosts =
  getRelatedPosts(
    allPosts,
    post
  );

const currentCluster =
  getCluster(
    post.data.category,
    post.id
  );

const clusterPosts =
  getClusterPosts(
    allPosts,
    currentCluster,
    post.id
  );

const currentLearningPath =
  getLearningPath(
    post.data.category,
    post.id
  );

const previousStep =
  getPreviousStep(
    currentLearningPath,
    post.id
  );

const nextStep =
  getNextStep(
    currentLearningPath,
    post.id
  );

const articleUrl =
  `https://www.aipraktis.co.id/blog/${post.id}/`;

const articleSchema =
  buildArticleSchema(
    post,
    articleUrl
  );

const breadcrumbSchema =
  buildBreadcrumbSchema([
    {
      name: "Home",
      url: "https://www.aipraktis.co.id/",
    },
    {
      name: "Blog",
      url: "https://www.aipraktis.co.id/blog/",
    },
    {
      name: post.data.title,
      url: articleUrl,
    },
  ]);

---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
>

  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
  />

  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />

<Content />

<BackToCategory
  slug={post.data.category}
/>

<CategoryHubCard
  slug={post.data.category}
/>

<LearningPathBox
  title={currentLearningPath?.title ?? ""}
  description={currentLearningPath?.description ?? ""}
  steps={currentLearningPath?.steps ?? []}
  currentSlug={post.id}
/>

<LearningPathNavigation
  previous={previousStep}
  next={nextStep}
/>

<SeriesProgress
  steps={currentLearningPath?.steps ?? []}
  currentSlug={post.id}
/>

<TopicClusterBox
  title={currentCluster?.title ?? ""}
  description={currentCluster?.description ?? ""}
  links={
    clusterPosts.map((item) => ({
      title: item!.data.title,
      url: `/blog/${item!.id}/`
    }))
  }
/>

<section class="related-posts">

  <h2>Artikel Terkait</h2>

  <ul>
    {
      relatedPosts.map((related) => (
        <li>
          <a href={`/blog/${related.id}/`}>
            {related.data.title}
          </a>
        </li>
      ))
    }
  </ul>

</section>

<RelatedLinks
  links={
    clusterPosts.map((item) => ({
      title: item!.data.title,
      url: `/blog/${item!.id}/`
    }))
  }
/>

</BlogLayout>