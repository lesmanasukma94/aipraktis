---
import { getCollection, render } from "astro:content";
import BlogLayout from "../../layouts/BlogLayout.astro";
import RelatedLinks from "@/components/blog/RelatedLinks.astro";
import BackToCategory from "@/components/blog/BackToCategory.astro";
import CategoryHubCard from "@/components/blog/CategoryHubCard.astro";
import TopicClusterBox from "@/components/blog/TopicClusterBox.astro";
import LearningPathBox from "@/components/blog/LearningPathBox.astro";
import { learningPaths } from "@/data/learning-paths";
import LearningPathNavigation from "@/components/blog/LearningPathNavigation.astro";
import SeriesProgress from "@/components/blog/SeriesProgress.astro";

import { topicClusters } from "@/data/clusters";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: {
      slug: post.id,
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const allPosts = await getCollection("blog");

const relatedPosts = allPosts
  .filter(
    (p) =>
      p.id !== post.id &&
      p.data.category === post.data.category
  )
  .slice(0, 5);

if (relatedPosts.length < 5) {

  const additionalPosts = allPosts
    .filter(
      (p) =>
        p.id !== post.id &&
        p.data.category !== post.data.category
    )
    .slice(0, 5 - relatedPosts.length);

  relatedPosts.push(...additionalPosts);

}

const currentCluster = topicClusters.find(
  (cluster) =>
    cluster.category === post.data.category &&
    cluster.articles.includes(post.id)
);

const clusterSlugs =
  currentCluster?.articles ?? [];

const clusterPosts = clusterSlugs
  .filter((slug) => slug !== post.id)
  .map((slug) =>
    allPosts.find((p) => p.id === slug)
  )
  .filter(Boolean);

const currentLearningPath = learningPaths.find(
  (path) =>
    path.category === post.data.category &&
    path.steps.some((step) => step.slug === post.id)
);

const currentStepIndex =
  currentLearningPath?.steps.findIndex(
    (step) => step.slug === post.id
  ) ?? -1;

const previousStep =
  currentStepIndex > 0
    ? currentLearningPath?.steps[currentStepIndex - 1]
    : undefined;

const nextStep =
  currentLearningPath &&
  currentStepIndex < currentLearningPath.steps.length - 1
    ? currentLearningPath.steps[currentStepIndex + 1]
    : undefined;

const articleUrl =
  `https://www.aipraktis.co.id/blog/${post.id}/`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",

  headline: post.data.title,

  description: post.data.description,

  datePublished: post.data.pubDate,

  dateModified: post.data.pubDate,

  author: {
    "@type": "Organization",
    name: "AI Praktis Indonesia"
  },

  publisher: {
    "@type": "Organization",
    name: "AI Praktis Indonesia",

    logo: {
      "@type": "ImageObject",
      url: "https://www.aipraktis.co.id/og-image.jpg"
    }
  },

  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": articleUrl
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",

  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Home",
      item: "https://www.aipraktis.co.id/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: "https://www.aipraktis.co.id/blog/"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: articleUrl
    }
  ]
};
---

<BlogLayout
  title={post.data.title}
  description={post.data.description}
>

  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(articleSchema)}
  />

  <script
    slot="head"
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
  />

<Content />

<BackToCategory
  slug={post.data.category}
/>

<CategoryHubCard
  slug={post.data.category}
/>

<LearningPathBox
  title={currentLearningPath?.title ?? ""}
  description={currentLearningPath?.description ?? ""}
  steps={currentLearningPath?.steps ?? []}
  currentSlug={post.id}
/>

<LearningPathNavigation
  previous={previousStep}
  next={nextStep}
/>

<SeriesProgress
  steps={currentLearningPath?.steps ?? []}
  currentSlug={post.id}
/>

<TopicClusterBox
  title={currentCluster?.title ?? ""}
  description={currentCluster?.description ?? ""}
  links={
    clusterPosts.map((item) => ({
      title: item!.data.title,
      url: `/blog/${item!.id}/`
    }))
  }
/>

<section class="related-posts">

  <h2>Artikel Terkait</h2>

  <ul>
    {
      relatedPosts.map((related) => (
        <li>
          <a href={`/blog/${related.id}/`}>
            {related.data.title}
          </a>
        </li>
      ))
    }
  </ul>

</section>

<RelatedLinks
  links={
    clusterPosts.map((item) => ({
      title: item!.data.title,
      url: `/blog/${item!.id}/`
    }))
  }
/>

</BlogLayout>