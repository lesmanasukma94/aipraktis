---
import MainLayout from '../layouts/MainLayout.astro';

const topics = [
  {
    title: "ChatGPT",
    desc: "Belajar menggunakan ChatGPT untuk pekerjaan sehari-hari."
  },
  {
    title: "Gemini",
    desc: "Panduan menggunakan Gemini dari Google."
  },
  {
    title: "Claude",
    desc: "Belajar AI Claude untuk menulis dan analisis."
  },
  {
    title: "Perplexity",
    desc: "Belajar riset menggunakan AI Search."
  },
  {
    title: "Midjourney",
    desc: "Membuat gambar AI profesional."
  },
  {
    title: "AI untuk UMKM",
    desc: "Menggunakan AI untuk meningkatkan bisnis."
  }
];
---

<MainLayout>
  <section class="container">
    <h1>Belajar AI</h1>

    <p>
      Kumpulan panduan AI praktis untuk pekerja dan UMKM Indonesia.
    </p>

    <div class="grid">
      {
        topics.map((topic) => (
          <div class="card">
            <h3>{topic.title}</h3>
            <p>{topic.desc}</p>
          </div>
        ))
      }
    </div>
  </section>
</MainLayout>

<style>
.container {
  max-width: 1200px;
  margin: auto;
  padding: 60px 20px;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 40px;
}

.card {
  padding: 20px;
  border: 1px solid #ddd;
  border-radius: 12px;
}

.card:hover {
  transform: translateY(-3px);
}

@media(max-width:768px){
  .grid{
    grid-template-columns:1fr;
  }
}
</style>