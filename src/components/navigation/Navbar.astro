---
import { SITE } from "@/config/site";
import NavLink from "./NavLink.astro";
---

<nav class="hidden lg:block">
  <ul class="flex items-center gap-8">
    {
      SITE.navigation.map((item) => (
        <li>
          <NavLink href={item.href}>
            {item.label}
          </NavLink>
        </li>
      ))
    }
  </ul>
</nav>