<div
  class="consent-banner"
  data-consent-banner
  role="dialog"
  aria-labelledby="consent-title"
  aria-describedby="consent-description"
  hidden
>
  <div class="consent-banner__content">

    <div class="consent-banner__text">
      <h2 id="consent-title">
        Pengaturan privasi
      </h2>

      <p id="consent-description">
        Kami menggunakan Google Analytics dan Microsoft Clarity untuk
        memahami penggunaan website dan meningkatkan pengalaman pembaca.
        Anda dapat menerima atau menolak penyimpanan analitik.
      </p>

      <p class="consent-banner__links">
        Baca
        <a href="/privacy-policy/">
          Kebijakan Privasi
        </a>
        dan
        <a href="/cookie-policy/">
          Kebijakan Cookie
        </a>.
      </p>
    </div>

    <div class="consent-banner__actions">

      <button
        type="button"
        class="consent-button consent-button--secondary"
        data-consent-reject
      >
        Tolak analitik
      </button>

      <button
        type="button"
        class="consent-button consent-button--primary"
        data-consent-accept
      >
        Terima analitik
      </button>

    </div>

  </div>
</div>

<button
  type="button"
  class="privacy-settings-button"
  data-consent-settings
  aria-label="Buka pengaturan privasi"
  hidden
>
  Privasi
</button>

<script is:inline>
  (function () {
    const STORAGE_KEY = "aipraktis-consent-v1";

    const banner =
      document.querySelector("[data-consent-banner]");

    const acceptButton =
      document.querySelector("[data-consent-accept]");

    const rejectButton =
      document.querySelector("[data-consent-reject]");

    const settingsButton =
      document.querySelector("[data-consent-settings]");

    if (
      !banner ||
      !acceptButton ||
      !rejectButton ||
      !settingsButton
    ) {
      return;
    }

    function readConsent() {
      try {
        return window.localStorage.getItem(STORAGE_KEY);
      } catch (error) {
        return null;
      }
    }

    function saveConsent(value) {
      try {
        window.localStorage.setItem(
          STORAGE_KEY,
          value
        );
      } catch (error) {
        console.warn(
          "Pilihan privasi tidak dapat disimpan.",
          error
        );
      }
    }

    function updateGoogleConsent(value) {
      const analyticsGranted =
        value === "granted";

      if (typeof window.gtag === "function") {
        window.gtag("consent", "update", {
          analytics_storage:
            analyticsGranted
              ? "granted"
              : "denied",

          ad_storage: "denied",
          ad_user_data: "denied",
          ad_personalization: "denied",
        });
      }
    }

    function showBanner() {
      banner.hidden = false;
      settingsButton.hidden = true;

      window.setTimeout(() => {
        rejectButton.focus();
      }, 0);
    }

    function hideBanner() {
      banner.hidden = true;
      settingsButton.hidden = false;
    }

    function setConsent(value) {
      saveConsent(value);
      updateGoogleConsent(value);
      hideBanner();
    }

    acceptButton.addEventListener(
      "click",
      function () {
        setConsent("granted");
      }
    );

    rejectButton.addEventListener(
      "click",
      function () {
        setConsent("denied");
      }
    );

    settingsButton.addEventListener(
      "click",
      function () {
        showBanner();
      }
    );

    const storedConsent = readConsent();

    if (
      storedConsent === "granted" ||
      storedConsent === "denied"
    ) {
      settingsButton.hidden = false;
    } else {
      showBanner();
    }
  })();
</script>

