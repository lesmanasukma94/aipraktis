---
import { categories } from "@/data/categories";

export interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const relatedCategories = categories.filter(
  (category) => category.slug !== currentSlug
);
---

<section class="related-categories">

  <h2>Jelajahi Kategori Lain</h2>

  <p class="section-description">
    Pelajari topik AI lainnya untuk memperluas wawasan dan keterampilan Anda.
  </p>

  <div class="category-grid">

    {
      relatedCategories.map((category) => (

        <a
          href={`/${category.slug}/`}
          class="category-card"
        >

          <h3>{category.name}</h3>

          <p>{category.description}</p>

        </a>

      ))
    }

  </div>

</section>

<style>
.related-categories{
  margin-top:64px;
}

.related-categories h2{
  margin-bottom:12px;
}

.section-description{
  margin-bottom:28px;
  color:#6b7280;
}

.category-grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(240px,1fr));
  gap:20px;
}

.category-card{
  display:block;
  text-decoration:none;
  color:inherit;

  border:1px solid #e5e7eb;
  border-radius:12px;
  padding:20px;

  transition:.2s ease;
}

.category-card:hover{
  border-color:#2563eb;
  transform:translateY(-2px);
}

.category-card h3{
  margin-bottom:10px;
}

.category-card p{
  font-size:.95rem;
  line-height:1.6;
  color:#6b7280;
}
</style>