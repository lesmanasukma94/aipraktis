---
export interface Props {
  category: {
    name: string;
    slug: string;
  };
}

const { category } = Astro.props;
---

<section class="category-cta">

  <div class="cta-box">

    <h2>Ingin Belajar {category.name} Lebih Mendalam?</h2>

    <p>
      Jelajahi seluruh artikel dalam kategori ini dan pelajari penerapan AI secara bertahap melalui panduan yang mudah dipahami.
    </p>

    <div class="cta-buttons">

      <a
        class="btn-primary"
        href="/belajar-ai"
      >
        Mulai Belajar AI
      </a>

      <a
        class="btn-secondary"
        href="/ai-tools"
      >
        Lihat AI Tools
      </a>

    </div>

  </div>

</section>

<style>
.category-cta{
  margin:64px 0;
}

.cta-box{
  border:1px solid #e5e7eb;
  border-radius:16px;
  padding:40px;
  text-align:center;
}

.cta-box h2{
  margin-bottom:16px;
}

.cta-box p{
  max-width:700px;
  margin:0 auto 24px;
  line-height:1.8;
}

.cta-buttons{
  display:flex;
  justify-content:center;
  gap:16px;
  flex-wrap:wrap;
}

.btn-primary,
.btn-secondary{
  display:inline-block;
  padding:12px 24px;
  border-radius:10px;
  text-decoration:none;
}

.btn-primary{
  background:#2563eb;
  color:#fff;
}

.btn-secondary{
  border:1px solid #2563eb;
  color:#2563eb;
}
</style>