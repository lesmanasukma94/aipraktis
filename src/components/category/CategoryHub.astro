---
export interface Article {

  id: string;

  data: {

    title: string;

    description: string;

    pubDate: Date;

  };

}

export interface Props {

  title: string;

  description: string;

  articles: Article[];

}

const {

  title,

  description,

  articles,

} = Astro.props;
---

<section class="category-hero">

  <div class="container">

    <h1>{title}</h1>

    <p>{description}</p>

  </div>

</section>

<section class="container">

  <div class="article-grid">

    {
      articles.map((article) => (

        <article class="article-card">

          <h2>

            <a href={`/blog/${article.id}/`}>

              {article.data.title}

            </a>

          </h2>

          <p>

            {article.data.description}

          </p>

        </article>

      ))
    }

  </div>

</section>

<style>

.category-hero{

padding:80px 0;

background:#f8fafc;

border-bottom:1px solid #e5e7eb;

}

.container{

max-width:1100px;

margin:auto;

padding:0 20px;

}

.category-hero h1{

font-size:48px;

margin-bottom:20px;

}

.category-hero p{

font-size:20px;

max-width:800px;

color:#64748b;

}

.article-grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(320px,1fr));

gap:24px;

padding:60px 0;

}

.article-card{

background:white;

border:1px solid #e5e7eb;

border-radius:16px;

padding:24px;

transition:.25s;

}

.article-card:hover{

transform:translateY(-4px);

box-shadow:0 10px 30px rgba(0,0,0,.08);

}

.article-card h2{

margin-top:0;

font-size:24px;

}

.article-card a{

text-decoration:none;

}

</style>