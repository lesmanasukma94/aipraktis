---
import { categories } from "@/data/categories";

export interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const otherCategories = categories.filter(
  (category) => category.slug !== currentSlug
);

const isLearningCategory =
  currentSlug === "belajar-ai";
---

<aside
  class="category-sidebar"
  aria-label="Navigasi kategori AI"
>

  <section class="sidebar-card">

    <h2>Kategori AI</h2>

    <p class="sidebar-card__intro">
      Jelajahi topik AI lainnya.
    </p>

    <ul>
      {
        otherCategories.map((category) => (
          <li>
            <a
              class="sidebar-link"
              href={`/${category.slug}/`}
            >
              <span>{category.name}</span>

              <span
                class="sidebar-link__arrow"
                aria-hidden="true"
              >
                →
              </span>
            </a>
          </li>
        ))
      }
    </ul>

  </section>

  <section class="sidebar-card sidebar-cta">

    <p class="sidebar-cta__label">
      Panduan Terstruktur
    </p>

    <h2>
      {
        isLearningCategory
          ? "Mulai dari Dasar"
          : "Belajar AI"
      }
    </h2>

    <p>
      {
        isLearningCategory
          ? "Ikuti urutan materi dari konsep dasar sampai penerapan praktis."
          : "Mulai perjalanan belajar AI dari dasar hingga tingkat lanjut."
      }
    </p>

    <a
      href={
        isLearningCategory
          ? "#learning-path"
          : "/belajar-ai/"
      }
    >
      {
        isLearningCategory
          ? "Lihat Learning Path"
          : "Mulai Belajar"
      }
    </a>

  </section>

</aside>

<style>
  .category-sidebar {
    position: sticky;
    top: 88px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sidebar-card {
    padding: 22px;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    background: #ffffff;
    box-shadow:
      0 8px 24px rgba(15, 23, 42, 0.035);
  }

  .sidebar-card h2 {
    margin: 0;
    color: #0f172a;
    font-size: 1.25rem;
    font-weight: 800;
    line-height: 1.3;
  }

  .sidebar-card__intro {
    margin: 7px 0 16px;
    color: #64748b;
    font-size: 0.875rem;
    line-height: 1.55;
  }

  .sidebar-card ul {
    display: grid;
    gap: 4px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .sidebar-card li {
    margin: 0;
  }

  .sidebar-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
    padding: 9px 10px;
    border-radius: 9px;
    color: #1d4ed8;
    font-size: 0.9rem;
    font-weight: 650;
    line-height: 1.4;
    text-decoration: none;
    transition:
      background-color 150ms ease,
      color 150ms ease,
      transform 150ms ease;
  }

  .sidebar-link:hover {
    background: #eff6ff;
    color: #1e40af;
    transform: translateX(2px);
  }

  .sidebar-link:focus-visible {
    outline: 3px solid #93c5fd;
    outline-offset: 2px;
  }

  .sidebar-link__arrow {
    color: #60a5fa;
  }

  .sidebar-cta {
    border-color: #2563eb;
    background:
      linear-gradient(
        145deg,
        #1d4ed8,
        #2563eb
      );
    color: #ffffff;
    box-shadow:
      0 14px 30px rgba(37, 99, 235, 0.2);
  }

  .sidebar-cta__label {
    margin: 0 0 7px;
    color: #bfdbfe;
    font-size: 0.7rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .sidebar-cta h2 {
    color: #ffffff;
  }

  .sidebar-cta > p:not(.sidebar-cta__label) {
    margin: 10px 0 0;
    color: #dbeafe;
    font-size: 0.9rem;
    line-height: 1.65;
  }

  .sidebar-cta > a {
    display: inline-flex;
    margin-top: 18px;
    padding: 10px 15px;
    border-radius: 9px;
    background: #ffffff;
    color: #1d4ed8;
    font-size: 0.875rem;
    font-weight: 800;
    text-decoration: none;
    transition:
      background-color 150ms ease,
      transform 150ms ease;
  }

  .sidebar-cta > a:hover {
    background: #eff6ff;
    transform: translateY(-1px);
  }

  .sidebar-cta > a:focus-visible {
    outline: 3px solid #bfdbfe;
    outline-offset: 3px;
  }

  @media (max-width: 960px) {
    .category-sidebar {
      position: static;
      display: grid;
      grid-template-columns:
        repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 640px) {
    .category-sidebar {
      grid-template-columns: 1fr;
    }
  }
</style>
