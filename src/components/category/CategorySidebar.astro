---
import { categories } from "@/data/categories";

export interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;

const otherCategories = categories.filter(
  (category) => category.slug !== currentSlug
);
---

<aside class="category-sidebar">

  <section class="sidebar-card">

    <h3>Kategori AI</h3>

    <ul>

      {
        otherCategories.map((category) => (

          <li>

            <a href={`/${category.slug}/`}>
              {category.name}
            </a>

          </li>

        ))
      }

    </ul>

  </section>

  <section class="sidebar-card cta">

    <h3>Belajar AI</h3>

    <p>
      Mulai perjalanan belajar AI dari dasar hingga tingkat lanjut.
    </p>

    <a href="/belajar-ai">
      Mulai Belajar
    </a>

  </section>

</aside>

<style>
.category-sidebar{
  display:flex;
  flex-direction:column;
  gap:24px;
}

.sidebar-card{
  border:1px solid #e5e7eb;
  border-radius:12px;
  padding:20px;
}

.sidebar-card h3{
  margin-bottom:16px;
}

.sidebar-card ul{
  list-style:none;
  padding:0;
  margin:0;
}

.sidebar-card li + li{
  margin-top:10px;
}

.sidebar-card a{
  text-decoration:none;
}

.cta a{
  display:inline-block;
  margin-top:12px;
  padding:10px 18px;
  border-radius:8px;
  background:#2563eb;
  color:#fff;
}
</style>