---
import { learningPaths } from "@/data/learning-paths";

export interface Props {
  category: string;
}

const { category } = Astro.props;

const paths = learningPaths.filter(
  (path) => path.category === category
);
---

{
  paths.length > 0 && (

<section class="category-learning-paths">

  <h2>Learning Path</h2>

  <p>
    Ikuti urutan belajar berikut agar materi dipelajari
    secara bertahap.
  </p>

  <div class="learning-path-grid">

    {
      paths.map((path) => (

<article class="learning-path-card">

  <h3>{path.title}</h3>

  <p>{path.description}</p>

  <ol>

    {
      path.steps.map((step) => (

<li>

  <a href={`/blog/${step.slug}/`}>
    {step.title}
  </a>

</li>

      ))
    }

  </ol>

  <p>

    {path.steps.length} langkah belajar

  </p>

</article>

      ))
    }

  </div>

</section>

  )
}