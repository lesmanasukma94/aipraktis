---
import { learningPaths } from "@/data/learning-paths";

export interface Props {
  category: string;
}

const { category } = Astro.props;

const paths = learningPaths.filter(
  (path) => path.category === category
);
---

{
  paths.length > 0 && (
    <section
      id="learning-path"
      class="category-learning-paths"
      aria-labelledby="learning-path-title"
    >
      <header class="section-header">

        <p class="section-eyebrow">
          Belajar Terstruktur
        </p>

        <h2 id="learning-path-title">
          Learning Path
        </h2>

        <p class="section-description">
          Ikuti urutan belajar berikut agar materi dipelajari
          secara bertahap dan lebih mudah dipahami.
        </p>

      </header>

      <div class="learning-path-grid">
        {
          paths.map((path) => (
            <article class="learning-path-card">

              <div class="learning-path-card__header">
                <h3>{path.title}</h3>

                <p>{path.description}</p>
              </div>

              <ol class="learning-step-list">
                {
                  path.steps.map((step, index) => (
                    <li>
                      <a
                        class="learning-step-link"
                        href={`/blog/${step.slug}/`}
                      >
                        <span
                          class="learning-step-number"
                          aria-hidden="true"
                        >
                          {index + 1}
                        </span>

                        <span class="learning-step-title">
                          {step.title}
                        </span>

                        <span
                          class="learning-step-arrow"
                          aria-hidden="true"
                        >
                          →
                        </span>
                      </a>
                    </li>
                  ))
                }
              </ol>

              <p class="learning-path-count">
                {path.steps.length} langkah belajar
              </p>

            </article>
          ))
        }
      </div>
    </section>
  )
}

<style>
  .category-learning-paths {
    scroll-margin-top: 96px;
  }

  .section-header {
    margin-bottom: 20px;
  }

  .section-eyebrow {
    margin: 0 0 6px;
    color: #2563eb;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .section-header h2 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(1.75rem, 3vw, 2.25rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.025em;
  }

  .section-description {
    max-width: 680px;
    margin: 10px 0 0;
    color: #64748b;
    font-size: 1rem;
    line-height: 1.7;
  }

  .learning-path-grid {
    display: grid;
    gap: 20px;
  }

  .learning-path-card {
    padding: clamp(22px, 4vw, 30px);
    border: 1px solid #e2e8f0;
    border-radius: 18px;
    background: #ffffff;
    box-shadow:
      0 8px 24px rgba(15, 23, 42, 0.04);
  }

  .learning-path-card__header {
    margin-bottom: 20px;
    padding-bottom: 18px;
    border-bottom: 1px solid #e2e8f0;
  }

  .learning-path-card h3 {
    margin: 0;
    color: #0f172a;
    font-size: clamp(1.3rem, 3vw, 1.625rem);
    font-weight: 800;
    line-height: 1.3;
  }

  .learning-path-card__header p {
    margin: 8px 0 0;
    color: #64748b;
    font-size: 0.9375rem;
    line-height: 1.65;
  }

  .learning-step-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .learning-step-link {
    display: grid;
    grid-template-columns: 34px minmax(0, 1fr) auto;
    gap: 12px;
    align-items: center;
    min-height: 52px;
    padding: 9px 12px;
    border: 1px solid #dbeafe;
    border-radius: 12px;
    background: #f8fbff;
    color: #1d4ed8;
    font-size: 0.9375rem;
    font-weight: 700;
    line-height: 1.45;
    text-decoration: none;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .learning-step-link:hover {
    border-color: #93c5fd;
    background: #eff6ff;
    color: #1e40af;
    transform: translateX(3px);
  }

  .learning-step-link:focus-visible {
    outline: 3px solid #93c5fd;
    outline-offset: 3px;
  }

  .learning-step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 10px;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 0.8125rem;
    font-weight: 800;
  }

  .learning-step-title {
    min-width: 0;
  }

  .learning-step-arrow {
    color: #2563eb;
    font-size: 1.1rem;
  }

  .learning-path-count {
    display: inline-flex;
    margin: 18px 0 0;
    padding: 6px 10px;
    border-radius: 999px;
    background: #f1f5f9;
    color: #475569;
    font-size: 0.8125rem;
    font-weight: 700;
    line-height: 1;
  }

  @media (max-width: 480px) {
    .learning-path-card {
      padding: 18px;
    }

    .learning-step-link {
      grid-template-columns: 32px minmax(0, 1fr);
    }

    .learning-step-arrow {
      display: none;
    }
  }
</style>
