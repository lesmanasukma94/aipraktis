---
import { vendors } from "@/data/vendors";
---

<section class="py-16 bg-gray-50">

  <div class="mx-auto max-w-7xl px-6">

    <h2 class="text-3xl font-bold mb-8">
      AI Chatbot Populer
    </h2>

    <div class="flex flex-wrap gap-3">

      {
        vendors.map((vendor) => (

          <a
            href={`/ai/${vendor.slug}/`}
            class="rounded-lg border px-4 py-2 hover:bg-blue-600 hover:text-white transition"
          >
            {vendor.name}
          </a>

        ))
      }

    </div>

  </div>

</section>