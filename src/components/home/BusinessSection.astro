---
import { homeBusiness } from "@/data/home";
---

<section class="business-center">

  <h2>
    AI untuk Bisnis & UMKM
  </h2>

  <p class="business-subtitle">
    Pelajari bagaimana Artificial Intelligence membantu meningkatkan penjualan, efisiensi operasional, pemasaran, dan pelayanan pelanggan.
  </p>

  <div class="business-grid">

    {
      homeBusiness.map((item) => (

        <a href={item.href} class="business-card">

          <h3>
            {item.title}
          </h3>

          <p>
            {item.description}
          </p>

        </a>

      ))
    }

  </div>

  <div class="business-button">

    <a href="/blog/pusat-ai-untuk-bisnis/">
      Lihat Semua Panduan AI Bisnis →
    </a>

  </div>

</section>