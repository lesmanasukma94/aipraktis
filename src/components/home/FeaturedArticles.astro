---
const { posts = [] } = Astro.props;

const featured = posts
  .sort((a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate))
  .slice(0, 6);
---

<section class="featured">

<div class="container">

<h2>Artikel Terbaru</h2>

<p>
Panduan AI terbaru yang terus diperbarui.
</p>

<div class="grid">

{
featured.map(post => (

<a
class="card"
href={`/blog/${post.id}/`}
>

<h3>{post.data.title}</h3>

<p>{post.data.description}</p>

<span>
Baca Selengkapnya →
</span>

</a>

))
}

</div>

</div>

</section>

<style>

.featured{

padding:90px 20px;

}

.container{

max-width:1200px;

margin:auto;

}

.grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(320px,1fr));

gap:24px;

margin-top:40px;

}

.card{

padding:24px;

border:1px solid #ececec;

border-radius:14px;

text-decoration:none;

color:inherit;

transition:.2s;

}

.card:hover{

border-color:#2563eb;

transform:translateY(-4px);

}

.card h3{

margin-bottom:12px;

}

.card p{

color:#666;

margin-bottom:20px;

}

.card span{

font-weight:700;

color:#2563eb;

}

</style>