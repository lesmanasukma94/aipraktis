---
import { homeCreator } from "@/data/home";
---

<section class="creator-center">

  <h2>
    AI untuk Content Creator
  </h2>

  <p class="creator-subtitle">
    Gunakan AI untuk membuat artikel, video, desain, YouTube, TikTok, Instagram, hingga optimasi SEO lebih cepat.
  </p>

  <div class="creator-grid">

    {
      homeCreator.map((item) => (

        <a href={item.href} class="creator-card">

          <h3>
            {item.title}
          </h3>

          <p>
            {item.description}
          </p>

        </a>

      ))
    }

  </div>

  <div class="creator-button">

    <a href="/blog/pusat-ai-untuk-content-creator/">
      Lihat Semua Panduan Content Creator →
    </a>

  </div>

</section>