---
const comparisons = [
  {
    title: "ChatGPT vs Claude",
    url: "/blog/claude-vs-chatgpt/",
  },
  {
    title: "Gemini vs ChatGPT",
    url: "/blog/perbedaan-chatgpt-dan-gemini/",
  },
  {
    title: "Claude vs Gemini",
    url: "/blog/claude-vs-gemini/",
  },
  {
    title: "DeepSeek vs ChatGPT",
    url: "/blog/deepseek-vs-chatgpt/",
  },
];
---

<section class="comparison">
  <div class="container">

    <h2>Perbandingan AI Tools</h2>

    <p>
      Bandingkan AI terbaik sebelum memilih.
    </p>

    <div class="grid">
      {
        comparisons.map((item) => (
          <a
            href={item.url}
            class="card"
          >
            <h3>{item.title}</h3>

            <span>
              Lihat Perbandingan →
            </span>
          </a>
        ))
      }
    </div>

  </div>
</section>

<style>
  .comparison {
    padding: 90px 20px;
    background: #f8fafc;
  }

  .container {
    max-width: 1100px;
    margin: auto;
  }

  .grid {
    margin-top: 40px;
    display: grid;
    grid-template-columns: repeat(
      auto-fit,
      minmax(260px, 1fr)
    );
    gap: 20px;
  }

  .card {
    padding: 24px;
    border-radius: 14px;
    border: 1px solid #ececec;
    background: white;
    text-decoration: none;
    color: inherit;
  }

  .card:hover {
    border-color: #2563eb;
  }

  .card span {
    display: block;
    margin-top: 20px;
    font-weight: 700;
    color: #2563eb;
  }
</style>