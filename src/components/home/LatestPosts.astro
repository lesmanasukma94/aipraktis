---
interface Post {
  id: string;
  slug: string;
  data: {
    title: string;
    description?: string;
    pubDate: Date;
  };
}

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
---

<section class="latest-posts">

  <h2>
    Artikel AI Terbaru
  </h2>

  <p class="latest-subtitle">
    Panduan terbaru seputar AI, ChatGPT, Gemini, Prompt Engineering, AI Tools, dan teknologi AI lainnya.
  </p>

  <div class="latest-grid">

    {
      posts.map((post) => (

        <article class="latest-card">

          <h3>

            <a href={`/blog/${post.slug}/`}>

              {post.data.title}

            </a>

          </h3>

          <p>

            {post.data.description}

          </p>

        </article>

      ))
    }

  </div>

</section>