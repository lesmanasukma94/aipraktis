---

<section class="categories">

  <div class="container">

    <div class="heading">

      <h2>Jelajahi Berdasarkan Kategori</h2>

      <p>
        Semua materi AI Praktis Indonesia disusun berdasarkan kategori agar
        lebih mudah dipelajari.
      </p>

    </div>

    <div class="grid">

      {
        categories.map((category) => (

          <a
            href={category.slug}
            class="card"
          >

            <div class="icon">
              {category.icon}
            </div>

            <h3>
              {category.title}
            </h3>

            <p>
              {category.description}
            </p>

          </a>

        ))
      }

    </div>

  </div>

</section>

<style>

.categories{

padding:80px 20px;

background:#fafafa;

}

.container{

max-width:1200px;

margin:auto;

}

.heading{

text-align:center;

margin-bottom:48px;

}

.heading h2{

font-size:2.2rem;

margin-bottom:12px;

}

.heading p{

max-width:700px;

margin:auto;

color:#666;

line-height:1.7;

}

.grid{

display:grid;

grid-template-columns:repeat(auto-fit,minmax(260px,1fr));

gap:24px;

}

.card{

display:block;

background:white;

border:1px solid #ececec;

border-radius:16px;

padding:24px;

text-decoration:none;

transition:.2s;

}

.card:hover{

transform:translateY(-4px);

border-color:#2563eb;

box-shadow:0 12px 30px rgba(0,0,0,.08);

}

.icon{

font-size:2rem;

margin-bottom:18px;

}

.card h3{

font-size:1.2rem;

color:#111827;

margin-bottom:12px;

}

.card p{

color:#666;

line-height:1.7;

font-size:.95rem;

}

</style>