---
import { categories } from "@/data/categories";

export interface Props {
  slug: string;
}

const { slug } = Astro.props;

const category = categories.find(
  (c) => c.slug === slug
);

if (!category) return;
---

<section class="category-hub-card">

  <h2>Pelajari Lebih Lanjut</h2>

  <p>
    Jelajahi seluruh artikel dalam kategori <strong>{category.name}</strong>.
  </p>

  <a
    class="hub-button"
    href={`/${category.slug}/`}
  >
    Lihat Semua Artikel {category.name}
  </a>

</section>

<style>
.category-hub-card{
  margin:64px 0;
  padding:32px;
  border:1px solid #e5e7eb;
  border-radius:16px;
  background:#f8fafc;
}

.category-hub-card h2{
  margin-bottom:12px;
}

.category-hub-card p{
  margin-bottom:20px;
  color:#4b5563;
}

.hub-button{
  display:inline-block;
  padding:12px 20px;
  border-radius:10px;
  background:#2563eb;
  color:#fff;
  text-decoration:none;
  font-weight:600;
}

.hub-button:hover{
  background:#1d4ed8;
}
</style>