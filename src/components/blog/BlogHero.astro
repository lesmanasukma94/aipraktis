---
import BlogBreadcrumb from "./BlogBreadcrumb.astro";
import BlogReadingTime from "./BlogReadingTime.astro";

export interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  updatedDate?: Date;
  category?: string;
  tags?: string[];
  author?: string;
  readingTime?: number;
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  category,
  tags = [],
  author = "AI Praktis Indonesia",
  readingTime,
} = Astro.props;

const dateFormat: Intl.DateTimeFormatOptions = {
  day: "numeric",
  month: "long",
  year: "numeric",
};

const categoryLabel = category
  ?.replaceAll("-", " ")
  .replace(/\b\w/g, (letter) => letter.toUpperCase());
---

<BlogBreadcrumb
  title={title}
  category={category}
/>

<header class="article-hero">

  {
    categoryLabel && (
      <div class="article-meta">
        <span class="article-category">
          {categoryLabel}
        </span>
      </div>
    )
  }

  <h1>{title}</h1>

  {
    description && (
      <p class="article-description">
        {description}
      </p>
    )
  }

  <div class="article-info">

    {
      pubDate && (
        <time datetime={pubDate.toISOString()}>
          Terbit {pubDate.toLocaleDateString("id-ID", dateFormat)}
        </time>
      )
    }

    {
      updatedDate && (
        <time datetime={updatedDate.toISOString()}>
          Diperbarui {updatedDate.toLocaleDateString("id-ID", dateFormat)}
        </time>
      )
    }

    <span>
      Oleh {author}
    </span>

    {
      readingTime && (
        <BlogReadingTime minutes={readingTime} />
      )
    }

  </div>

  {
    tags.length > 0 && (
      <div class="article-tags">
        {
          tags.map((tag) => (
            <span class="article-tag">
              {tag}
            </span>
          ))
        }
      </div>
    )
  }

</header>