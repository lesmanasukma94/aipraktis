---
export interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "outline" | "ghost";
  size?: "sm" | "md" | "lg";
  type?: "button" | "submit" | "reset";
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  type = "button",
  class: className = "",
} = Astro.props;

const variants = {
  primary:
    "bg-blue-600 text-white hover:bg-blue-700",

  secondary:
    "bg-slate-900 text-white hover:bg-slate-800",

  outline:
    "border border-slate-300 bg-white hover:bg-slate-50",

  ghost:
    "hover:bg-slate-100",
};

const sizes = {
  sm: "px-3 py-2 text-sm",
  md: "px-5 py-3",
  lg: "px-7 py-4 text-lg",
};

const classes = [
  "inline-flex items-center justify-center",
  "rounded-lg",
  "font-medium",
  "transition-colors",
  "duration-200",
  "focus:outline-none",
  "focus:ring-2",
  "focus:ring-blue-500",
  variants[variant],
  sizes[size],
  className,
].join(" ");
---

{
  href ? (
    <a href={href} class={classes}>
      <slot />
    </a>
  ) : (
    <button type={type} class={classes}>
      <slot />
    </button>
  )
}