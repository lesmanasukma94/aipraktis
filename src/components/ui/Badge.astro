---
export interface Props {
  variant?:
    | "primary"
    | "secondary"
    | "success"
    | "warning"
    | "danger"
    | "neutral";

  size?: "sm" | "md";

  rounded?: boolean;

  class?: string;
}

const {
  variant = "primary",
  size = "md",
  rounded = true,
  class: className = "",
} = Astro.props;

const variants = {
  primary:
    "bg-blue-100 text-blue-700",

  secondary:
    "bg-violet-100 text-violet-700",

  success:
    "bg-green-100 text-green-700",

  warning:
    "bg-amber-100 text-amber-700",

  danger:
    "bg-red-100 text-red-700",

  neutral:
    "bg-slate-100 text-slate-700",
};

const sizes = {
  sm: "px-2 py-1 text-xs",
  md: "px-3 py-1.5 text-sm",
};

const classes = [
  "inline-flex",
  "items-center",
  "justify-center",
  "font-medium",
  "whitespace-nowrap",
  rounded ? "rounded-full" : "rounded-lg",
  variants[variant],
  sizes[size],
  className,
].join(" ");
---

<span class={classes}>
  <slot />
</span>