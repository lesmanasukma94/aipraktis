---
export interface Props {
  gap?: "sm" | "md" | "lg" | "xl";
  class?: string;
}

const {
  gap = "md",
  class: className = "",
} = Astro.props;

const gaps = {
  sm: "space-y-2",
  md: "space-y-4",
  lg: "space-y-6",
  xl: "space-y-10",
};
---

<div
  class:list={[
    gaps[gap],
    className,
  ]}
>
  <slot />
</div>