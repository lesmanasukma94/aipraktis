---
import Container from "./Container.astro";
import { SITE } from "@/config/site";
---

<footer class="border-t border-slate-200 bg-slate-50">
  <Container>
    <div class="py-12">

      <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-[1.5fr_1fr_1fr]">

        <div>
          <h2 class="text-xl font-bold text-slate-900">
            {SITE.name}
          </h2>

          <p class="mt-3 max-w-md leading-7 text-slate-600">
            {SITE.description}
          </p>
        </div>

        <nav aria-label="Navigasi footer">
          <h2 class="font-semibold text-slate-900">
            Jelajahi
          </h2>

          <ul class="mt-4 space-y-3">
            {
              SITE.navigation.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-slate-600 transition-colors hover:text-blue-600"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <nav aria-label="Informasi dan kebijakan">
          <h2 class="font-semibold text-slate-900">
            Informasi
          </h2>

          <ul class="mt-4 space-y-3">
            {
              SITE.legalNavigation.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class="text-slate-600 transition-colors hover:text-blue-600"
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

      </div>

      <div
        class="mt-10 border-t border-slate-200 pt-6 text-sm text-slate-500"
      >
        © {new Date().getFullYear()} {SITE.name}. Hak cipta dilindungi.
      </div>

    </div>
  </Container>
</footer>